<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Concierge</title>
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --background: #0f1419;
      --foreground: #e7e9ea;
      --card: #16202a;
      --card-foreground: #e7e9ea;
      --primary: #22c997;
      --primary-foreground: #0f1419;
      --secondary: #1d2d3a;
      --secondary-foreground: #e7e9ea;
      --muted: #1d2d3a;
      --muted-foreground: #8b98a5;
      --border: #2f3b47;
      --input: #1d2d3a;
      --ring: #22c997;
      --radius: 12px;
      --destructive: #f4212e;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background-color: var(--background);
      color: var(--foreground);
      line-height: 1.5;
      min-height: 100vh;
    }

    #root { min-height: 100vh; display: flex; flex-direction: column; }

    /* Layout */
    .app-container { display: flex; flex-direction: column; height: 100vh; max-width: 900px; margin: 0 auto; width: 100%; }

    /* Header */
    .header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px; border-bottom: 1px solid var(--border);
      background: rgba(15, 20, 25, 0.8); backdrop-filter: blur(12px);
      position: sticky; top: 0; z-index: 50;
    }
    .header-title { display: flex; align-items: center; gap: 10px; }
    .header-title svg { color: var(--primary); }
    .header-title h1 { font-size: 1.25rem; font-weight: 600; }
    .header-tabs { display: flex; gap: 8px; align-items: center; }
    .persona-badge {
      display: flex; align-items: center; gap: 6px;
      background: rgba(34, 201, 151, 0.15); color: var(--primary);
      padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 500;
    }

    /* Buttons */
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      padding: 8px 16px; border-radius: var(--radius); font-size: 0.875rem;
      font-weight: 500; cursor: pointer; border: none; transition: all 0.2s;
    }
    .btn-primary { background: var(--primary); color: var(--primary-foreground); }
    .btn-primary:hover { background: #1db386; }
    .btn-ghost { background: transparent; color: var(--foreground); }
    .btn-ghost:hover { background: var(--secondary); }
    .btn-active { background: var(--primary); color: var(--primary-foreground); }
    .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--foreground); }
    .btn-outline:hover { background: var(--secondary); border-color: var(--primary); }
    .btn-icon { padding: 10px; border-radius: 50%; }
    .btn-recording { background: var(--destructive); color: white; animation: pulse 1.5s infinite; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }

    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }

    /* Chat Area */
    .chat-container { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    .messages-area { flex: 1; overflow-y: auto; padding: 24px 20px; }
    .messages-list { display: flex; flex-direction: column; gap: 8px; }

    /* Messages */
    .message { display: flex; margin-bottom: 4px; }
    .message-user { justify-content: flex-end; }
    .message-assistant { justify-content: flex-start; }
    .message-bubble {
      max-width: 80%; padding: 12px 16px; border-radius: 18px;
      font-size: 0.9375rem; line-height: 1.5;
    }
    .message-user .message-bubble {
      background: var(--primary); color: var(--primary-foreground);
      border-bottom-right-radius: 4px;
    }
    .message-assistant .message-bubble {
      background: var(--secondary); color: var(--foreground);
      border-bottom-left-radius: 4px;
    }

    /* Typing Indicator */
    .typing-indicator { display: flex; gap: 4px; padding: 8px 0; }
    .typing-dot {
      width: 8px; height: 8px; background: var(--muted-foreground);
      border-radius: 50%; animation: bounce 1.4s infinite ease-in-out;
    }
    .typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .typing-dot:nth-child(2) { animation-delay: -0.16s; }
    @keyframes bounce { 0%, 80%, 100% { transform: scale(0.8); } 40% { transform: scale(1.2); } }

    /* Input Area */
    .input-area {
      padding: 16px 20px; border-top: 1px solid var(--border);
      background: var(--background);
    }
    .input-wrapper {
      display: flex; align-items: flex-end; gap: 12px;
      background: var(--input); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 8px 12px;
      transition: border-color 0.2s;
    }
    .input-wrapper:focus-within { border-color: var(--primary); }
    .input-wrapper textarea {
      flex: 1; background: transparent; border: none; color: var(--foreground);
      font-size: 0.9375rem; resize: none; outline: none;
      min-height: 24px; max-height: 150px; line-height: 1.5;
      font-family: inherit;
    }
    .input-wrapper textarea::placeholder { color: var(--muted-foreground); }
    .recording-timer { color: var(--destructive); font-size: 0.875rem; font-weight: 500; min-width: 50px; }
    .voice-status { font-size: 0.75rem; color: var(--muted-foreground); margin-top: 8px; text-align: center; }

    /* Persona Card */
    .persona-section { padding: 16px 20px; background: rgba(34, 201, 151, 0.05); border-bottom: 1px solid var(--border); }
    .persona-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
    .persona-header {
      display: flex; justify-content: space-between; align-items: center;
      padding: 12px 16px; background: rgba(34, 201, 151, 0.1); border-bottom: 1px solid var(--border);
    }
    .persona-header-left { display: flex; align-items: center; gap: 10px; }
    .persona-header h3 { font-size: 0.9375rem; font-weight: 600; color: var(--primary); }
    .persona-close { background: transparent; border: none; color: var(--muted-foreground); cursor: pointer; padding: 4px; }
    .persona-close:hover { color: var(--foreground); }
    .persona-content { padding: 16px; }
    .persona-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; }
    .persona-item label { display: block; font-size: 0.75rem; color: var(--muted-foreground); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
    .persona-item span { font-size: 0.875rem; color: var(--foreground); font-weight: 500; }
    .persona-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
    .persona-tag { background: var(--secondary); color: var(--foreground); padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; }

    /* Resources */
    .resources-section { padding: 20px; border-top: 1px solid var(--border); }
    .resources-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .resources-header h3 { font-size: 1rem; font-weight: 600; color: var(--primary); }
    .resources-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
    .resource-card {
      background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 16px; transition: all 0.2s; cursor: pointer;
    }
    .resource-card:hover { border-color: var(--primary); transform: translateY(-2px); }
    .resource-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
    .resource-type { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--primary); font-weight: 600; }
    .resource-rating { display: flex; align-items: center; gap: 4px; font-size: 0.8rem; color: #fbbf24; }
    .resource-title { font-size: 1rem; font-weight: 600; margin-bottom: 6px; }
    .resource-desc { font-size: 0.8rem; color: var(--muted-foreground); line-height: 1.5; margin-bottom: 12px; }
    .resource-meta { display: flex; gap: 12px; font-size: 0.75rem; color: var(--muted-foreground); }
    .resource-meta span { display: flex; align-items: center; gap: 4px; }

    /* Roadmap */
    .roadmap-container { flex: 1; overflow-y: auto; padding: 24px 20px; }
    .roadmap-header { text-align: center; margin-bottom: 32px; }
    .roadmap-header h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 8px; }
    .roadmap-header p { color: var(--muted-foreground); }
    .roadmap-section { margin-bottom: 32px; }
    .roadmap-section-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
    .roadmap-icon { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .roadmap-icon.days1 { background: rgba(34, 201, 151, 0.15); color: var(--primary); }
    .roadmap-icon.days2 { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
    .roadmap-icon.hidden { background: rgba(251, 191, 36, 0.15); color: #fbbf24; }
    .roadmap-section-title h3 { font-size: 1.125rem; font-weight: 600; }
    .roadmap-section-title p { font-size: 0.8rem; color: var(--muted-foreground); }
    .roadmap-timeline { position: relative; padding-left: 24px; border-left: 2px solid var(--border); margin-left: 20px; }
    .roadmap-item { position: relative; padding: 16px; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 16px; }
    .roadmap-item::before {
      content: ''; position: absolute; left: -30px; top: 20px;
      width: 12px; height: 12px; border-radius: 50%;
      background: var(--primary); border: 2px solid var(--background);
    }
    .roadmap-item-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
    .roadmap-item-title { font-weight: 600; }
    .roadmap-item-day { font-size: 0.75rem; color: var(--primary); background: rgba(34, 201, 151, 0.1); padding: 2px 8px; border-radius: 10px; }
    .roadmap-item-desc { font-size: 0.875rem; color: var(--muted-foreground); margin-bottom: 12px; }
    .roadmap-item-tips { font-size: 0.8rem; color: var(--foreground); background: var(--secondary); padding: 10px 12px; border-radius: 8px; }
    .roadmap-item-tips strong { color: var(--primary); }
    .roadmap-empty { text-align: center; padding: 60px 20px; }
    .roadmap-empty p { color: var(--muted-foreground); margin-bottom: 20px; }

    /* Welcome */
    .welcome-screen { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 20px; text-align: center; }
    .welcome-icon { width: 80px; height: 80px; background: rgba(34, 201, 151, 0.1); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 24px; }
    .welcome-icon svg { width: 40px; height: 40px; color: var(--primary); }
    .welcome-screen h2 { font-size: 1.5rem; font-weight: 700; margin-bottom: 12px; }
    .welcome-screen p { color: var(--muted-foreground); max-width: 400px; margin-bottom: 32px; }
    .welcome-suggestions { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; max-width: 500px; }
    .suggestion-chip {
      background: var(--secondary); border: 1px solid var(--border); padding: 10px 16px;
      border-radius: 20px; font-size: 0.875rem; cursor: pointer; transition: all 0.2s;
    }
    .suggestion-chip:hover { border-color: var(--primary); background: rgba(34, 201, 151, 0.1); }

    /* Icons */
    .icon { width: 20px; height: 20px; flex-shrink: 0; }
    .icon-sm { width: 16px; height: 16px; }
    .icon-lg { width: 24px; height: 24px; }

    /* Responsive */
    @media (max-width: 640px) {
      .header { padding: 12px 16px; }
      .header-title h1 { font-size: 1.1rem; }
      .btn { padding: 8px 12px; font-size: 0.8rem; }
      .messages-area { padding: 16px; }
      .message-bubble { max-width: 85%; padding: 10px 14px; font-size: 0.875rem; }
      .input-area { padding: 12px 16px; }
      .resources-grid { grid-template-columns: 1fr; }
      .persona-grid { grid-template-columns: 1fr 1fr; }
      .roadmap-container { padding: 16px; }
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--muted-foreground); }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useRef } = React;

    // Icons as components
    const Icons = {
      Sparkles: () => (
        <svg className="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
          <path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/>
        </svg>
      ),
      MessageSquare: () => (
        <svg className="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      ),
      Map: () => (
        <svg className="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/>
          <line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/>
        </svg>
      ),
      Mic: () => (
        <svg className="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
          <path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/>
        </svg>
      ),
      Send: () => (
        <svg className="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      ),
      X: () => (
        <svg className="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      ),
      Star: () => (
        <svg className="icon-sm" viewBox="0 0 24 24" fill="currentColor">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
      ),
      Clock: () => (
        <svg className="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
      ),
      Calendar: () => (
        <svg className="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      ),
      Compass: () => (
        <svg className="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>
        </svg>
      ),
      Gem: () => (
        <svg className="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <path d="M6 3h12l4 6-10 13L2 9Z"/><path d="M11 3 8 9l4 13 4-13-3-6"/><path d="M2 9h20"/>
        </svg>
      ),
      Loader: () => (
        <svg className="icon animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
          <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
      ),
      User: () => (
        <svg className="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
      )
    };

    // Chat Message Component
    function ChatMessage({ message }) {
      const isUser = message.role === 'user';
      return (
        <div className={`message ${isUser ? 'message-user' : 'message-assistant'}`}>
          <div className="message-bubble">{message.content}</div>
        </div>
      );
    }

    // Typing Indicator
    function TypingIndicator() {
      return (
        <div className="message message-assistant">
          <div className="message-bubble">
            <div className="typing-indicator">
              <div className="typing-dot"></div>
              <div className="typing-dot"></div>
              <div className="typing-dot"></div>
            </div>
          </div>
        </div>
      );
    }

    // Persona Card
    function PersonaCard({ persona, onClose }) {
      if (!persona) return null;
      
      const fields = [
        { key: 'travel_style', label: 'Travel Style' },
        { key: 'budget', label: 'Budget' },
        { key: 'pace', label: 'Pace' },
        { key: 'accommodation', label: 'Accommodation' }
      ];

      return (
        <div className="persona-section">
          <div className="persona-card">
            <div className="persona-header">
              <div className="persona-header-left">
                <Icons.User />
                <h3>Your Travel Persona</h3>
              </div>
              <button className="persona-close" onClick={onClose}>
                <Icons.X />
              </button>
            </div>
            <div className="persona-content">
              <div className="persona-grid">
                {fields.map(({ key, label }) => persona[key] && (
                  <div key={key} className="persona-item">
                    <label>{label}</label>
                    <span>{persona[key]}</span>
                  </div>
                ))}
              </div>
              {persona.interests && persona.interests.length > 0 && (
                <div className="persona-item" style={{ marginTop: '16px' }}>
                  <label>Interests</label>
                  <div className="persona-tags">
                    {persona.interests.map((interest, i) => (
                      <span key={i} className="persona-tag">{interest}</span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      );
    }

    // Resource Card
    function ResourceCard({ resource }) {
      return (
        <div className="resource-card">
          <div className="resource-header">
            <span className="resource-type">{resource.type}</span>
            <span className="resource-rating">
              <Icons.Star />
              {resource.rating}
            </span>
          </div>
          <h4 className="resource-title">{resource.title}</h4>
          <p className="resource-desc">{resource.description}</p>
          <div className="resource-meta">
            <span><Icons.Clock /> {resource.duration}</span>
            {resource.location && <span>{resource.location}</span>}
          </div>
        </div>
      );
    }

    // Resources Grid
    function ResourcesGrid({ resources }) {
      if (!resources || resources.length === 0) return null;
      
      return (
        <div className="resources-section">
          <div className="resources-header">
            <h3>Recommended Resources</h3>
          </div>
          <div className="resources-grid">
            {resources.map((resource, index) => (
              <ResourceCard key={index} resource={resource} />
            ))}
          </div>
        </div>
      );
    }

    // Roadmap Section
    function RoadmapSection({ title, subtitle, items, icon: Icon, iconClass }) {
      return (
        <div className="roadmap-section">
          <div className="roadmap-section-header">
            <div className={`roadmap-icon ${iconClass}`}>
              <Icon />
            </div>
            <div className="roadmap-section-title">
              <h3>{title}</h3>
              <p>{subtitle}</p>
            </div>
          </div>
          <div className="roadmap-timeline">
            {items.map((item, index) => (
              <div key={index} className="roadmap-item">
                <div className="roadmap-item-header">
                  <span className="roadmap-item-title">{item.title}</span>
                  {item.day && <span className="roadmap-item-day">Day {item.day}</span>}
                </div>
                <p className="roadmap-item-desc">{item.description}</p>
                {item.tips && (
                  <div className="roadmap-item-tips">
                    <strong>Tip:</strong> {item.tips}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      );
    }

    // Roadmap Display
    function RoadmapDisplay({ roadmap, isLoading, onGenerate }) {
      if (isLoading) {
        return (
          <div className="roadmap-container">
            <div className="roadmap-empty">
              <div style={{ display: 'flex', justifyContent: 'center', marginBottom: '16px' }}>
                <Icons.Loader />
              </div>
              <p>Generating your personalized roadmap...</p>
            </div>
          </div>
        );
      }

      if (!roadmap) {
        return (
          <div className="roadmap-container">
            <div className="roadmap-empty">
              <div className="welcome-icon" style={{ margin: '0 auto 24px' }}>
                <Icons.Map />
              </div>
              <p>Generate a personalized travel roadmap based on your preferences and conversations.</p>
              <button className="btn btn-primary" onClick={onGenerate}>
                <Icons.Sparkles />
                Generate Roadmap
              </button>
            </div>
          </div>
        );
      }

      return (
        <div className="roadmap-container">
          <div className="roadmap-header">
            <h2>{roadmap.title || 'Your Travel Roadmap'}</h2>
            <p>{roadmap.description || 'A personalized itinerary just for you'}</p>
          </div>
          
          {roadmap.days_1_5 && roadmap.days_1_5.length > 0 && (
            <RoadmapSection
              title="Days 1-5"
              subtitle="Getting started with your adventure"
              items={roadmap.days_1_5}
              icon={Icons.Calendar}
              iconClass="days1"
            />
          )}
          
          {roadmap.days_6_10 && roadmap.days_6_10.length > 0 && (
            <RoadmapSection
              title="Days 6-10"
              subtitle="Deeper exploration"
              items={roadmap.days_6_10}
              icon={Icons.Compass}
              iconClass="days2"
            />
          )}
          
          {roadmap.hidden_gems && roadmap.hidden_gems.length > 0 && (
            <RoadmapSection
              title="Hidden Gems"
              subtitle="Off the beaten path discoveries"
              items={roadmap.hidden_gems}
              icon={Icons.Gem}
              iconClass="hidden"
            />
          )}
        </div>
      );
    }

    // Chat Input
    function ChatInput({ onSend, onVoiceResult, isLoading, placeholder }) {
      const [message, setMessage] = useState('');
      const [isRecording, setIsRecording] = useState(false);
      const [recordingTime, setRecordingTime] = useState(0);
      const [voiceStatus, setVoiceStatus] = useState('');
      const textareaRef = useRef(null);
      const mediaRecorderRef = useRef(null);
      const chunksRef = useRef([]);
      const timerRef = useRef(null);

      const handleSubmit = () => {
        if (message.trim() && !isLoading) {
          onSend(message.trim());
          setMessage('');
          if (textareaRef.current) {
            textareaRef.current.style.height = 'auto';
          }
        }
      };

      const handleKeyDown = (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          handleSubmit();
        }
      };

      const handleTextareaChange = (e) => {
        setMessage(e.target.value);
        e.target.style.height = 'auto';
        e.target.style.height = Math.min(e.target.scrollHeight, 150) + 'px';
      };

      const startRecording = async () => {
        try {
          const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
          mediaRecorderRef.current = new MediaRecorder(stream);
          chunksRef.current = [];

          mediaRecorderRef.current.ondataavailable = (e) => {
            if (e.data.size > 0) chunksRef.current.push(e.data);
          };

          mediaRecorderRef.current.onstop = async () => {
            const blob = new Blob(chunksRef.current, { type: 'audio/webm' });
            stream.getTracks().forEach(track => track.stop());
            await sendVoice(blob);
          };

          mediaRecorderRef.current.start();
          setIsRecording(true);
          setRecordingTime(0);
          setVoiceStatus('Recording...');
          
          timerRef.current = setInterval(() => {
            setRecordingTime(prev => prev + 1);
          }, 1000);
        } catch (err) {
          setVoiceStatus('Microphone access denied');
          setTimeout(() => setVoiceStatus(''), 3000);
        }
      };

      const stopRecording = () => {
        if (mediaRecorderRef.current && isRecording) {
          mediaRecorderRef.current.stop();
          setIsRecording(false);
          clearInterval(timerRef.current);
          setVoiceStatus('Processing...');
        }
      };

      const sendVoice = async (blob) => {
        try {
          const formData = new FormData();
          formData.append('file', blob, 'recording.webm');
          
          const response = await fetch('http://127.0.0.1:8000/voice', {
            method: 'POST',
            body: formData,
          });
          
          if (response.ok) {
            const data = await response.json();
            setVoiceStatus('Voice processed!');
            if (onVoiceResult) onVoiceResult(data);
          } else {
            throw new Error('Voice processing failed');
          }
        } catch (err) {
          // Demo fallback
          const demoPersona = {
            travel_style: 'Adventure',
            budget: 'Moderate',
            pace: 'Balanced',
            accommodation: 'Boutique Hotels',
            interests: ['Local cuisine', 'Historical sites', 'Nature walks'],
            message: "I've analyzed your voice and created a travel persona for you!"
          };
          setVoiceStatus('Using demo mode');
          if (onVoiceResult) onVoiceResult(demoPersona);
        }
        setTimeout(() => setVoiceStatus(''), 3000);
      };

      const formatTime = (seconds) => {
        const mins = Math.floor(seconds / 60);
        const secs = seconds % 60;
        return `${mins}:${secs.toString().padStart(2, '0')}`;
      };

      return (
        <div className="input-area">
          <div className="input-wrapper">
            <button
              className={`btn btn-icon ${isRecording ? 'btn-recording' : 'btn-outline'}`}
              onClick={isRecording ? stopRecording : startRecording}
              disabled={isLoading}
            >
              <Icons.Mic />
            </button>
            
            {isRecording && (
              <span className="recording-timer">{formatTime(recordingTime)}</span>
            )}
            
            <textarea
              ref={textareaRef}
              value={message}
              onChange={handleTextareaChange}
              onKeyDown={handleKeyDown}
              placeholder={placeholder || "Type your message..."}
              rows={1}
              disabled={isLoading || isRecording}
            />
            
            <button
              className="btn btn-icon btn-primary"
              onClick={handleSubmit}
              disabled={!message.trim() || isLoading || isRecording}
            >
              {isLoading ? <Icons.Loader /> : <Icons.Send />}
            </button>
          </div>
          {voiceStatus && <div className="voice-status">{voiceStatus}</div>}
        </div>
      );
    }

    // Welcome Screen
    function WelcomeScreen({ onSuggestionClick }) {
      const suggestions = [
        "Plan a trip to Tokyo",
        "Best restaurants in Paris",
        "Hidden gems in Barcelona",
        "Family-friendly activities"
      ];

      return (
        <div className="welcome-screen">
          <div className="welcome-icon">
            <Icons.Sparkles />
          </div>
          <h2>Welcome to AI Concierge</h2>
          <p>Your intelligent travel assistant. Ask me about destinations, get personalized recommendations, or use voice to describe your ideal trip.</p>
          <div className="welcome-suggestions">
            {suggestions.map((suggestion, index) => (
              <button
                key={index}
                className="suggestion-chip"
                onClick={() => onSuggestionClick(suggestion)}
              >
                {suggestion}
              </button>
            ))}
          </div>
        </div>
      );
    }

    // Main App
    function App() {
      const [messages, setMessages] = useState([]);
      const [isLoading, setIsLoading] = useState(false);
      const [activeTab, setActiveTab] = useState('chat');
      const [roadmap, setRoadmap] = useState(null);
      const [isLoadingRoadmap, setIsLoadingRoadmap] = useState(false);
      const [persona, setPersona] = useState(null);
      const [resources, setResources] = useState([]);
      const messagesEndRef = useRef(null);

      useEffect(() => {
        messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
      }, [messages]);

      const handleSendMessage = async (content) => {
        const userMessage = { id: Date.now().toString(), role: 'user', content };
        setMessages(prev => [...prev, userMessage]);
        setIsLoading(true);

        try {
          const response = await fetch('http://127.0.0.1:8000/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: content }),
          });

          if (response.ok) {
            const data = await response.json();
            const aiMessage = {
              id: (Date.now() + 1).toString(),
              role: 'assistant',
              content: data.response || data.message
            };
            setMessages(prev => [...prev, aiMessage]);
            if (data.resources) setResources(data.resources);
          } else {
            throw new Error('Chat failed');
          }
        } catch (err) {
          // Demo response
          const demoResponses = [
            "I'd love to help you plan your perfect trip! Based on your interests, I recommend exploring local markets and trying authentic street food.",
            "That's a great destination choice! The best time to visit would be during spring when the weather is mild and crowds are smaller.",
            "For that area, I suggest staying in the historic district. You'll be close to major attractions and have easy access to local restaurants."
          ];
          const aiMessage = {
            id: (Date.now() + 1).toString(),
            role: 'assistant',
            content: demoResponses[Math.floor(Math.random() * demoResponses.length)]
          };
          setMessages(prev => [...prev, aiMessage]);
          
          // Demo resources
          setResources([
            { type: 'Restaurant', title: 'La Maison', description: 'Fine dining with local ingredients', rating: 4.8, duration: '2 hours' },
            { type: 'Activity', title: 'Walking Tour', description: 'Explore historic neighborhoods', rating: 4.9, duration: '3 hours' },
            { type: 'Attraction', title: 'Central Museum', description: 'World-class art collection', rating: 4.7, duration: '2-3 hours' }
          ]);
        }
        setIsLoading(false);
      };

      const handleVoiceResult = (data) => {
        setPersona(data);
        const voiceMessage = {
          id: Date.now().toString(),
          role: 'assistant',
          content: data.message || "I've analyzed your voice input and created a travel persona for you!"
        };
        setMessages(prev => [...prev, voiceMessage]);
      };

      const handleGenerateRoadmap = async () => {
        setIsLoadingRoadmap(true);
        try {
          const response = await fetch('http://127.0.0.1:8000/roadmap');
          if (response.ok) {
            const data = await response.json();
            setRoadmap(data);
          } else {
            throw new Error('Roadmap failed');
          }
        } catch (err) {
          // Demo roadmap
          setRoadmap({
            title: 'Your Adventure Awaits',
            description: 'A curated 10-day journey',
            days_1_5: [
              { day: 1, title: 'Arrival & Orientation', description: 'Settle in and explore your neighborhood', tips: 'Take it easy on day one to adjust' },
              { day: 2, title: 'Historic District', description: 'Walking tour of old town', tips: 'Wear comfortable shoes' },
              { day: 3, title: 'Local Markets', description: 'Food tour and cooking class', tips: 'Come hungry!' }
            ],
            days_6_10: [
              { day: 6, title: 'Day Trip Adventure', description: 'Explore nearby attractions', tips: 'Book transportation in advance' },
              { day: 8, title: 'Cultural Immersion', description: 'Museum visits and local events', tips: 'Check for special exhibitions' }
            ],
            hidden_gems: [
              { title: 'Secret Garden', description: 'A peaceful retreat known only to locals', tips: 'Visit early morning' },
              { title: 'Artisan Quarter', description: 'Small workshops and unique crafts', tips: 'Great for souvenirs' }
            ]
          });
        }
        setIsLoadingRoadmap(false);
      };

      return (
        <div className="app-container">
          {/* Header */}
          <header className="header">
            <div className="header-title">
              <Icons.Sparkles />
              <h1>AI Concierge</h1>
            </div>
            <div className="header-tabs">
              <button
                className={`btn ${activeTab === 'chat' ? 'btn-active' : 'btn-ghost'}`}
                onClick={() => setActiveTab('chat')}
              >
                <Icons.MessageSquare />
                <span className="hide-mobile">Chat</span>
              </button>
              <button
                className={`btn ${activeTab === 'roadmap' ? 'btn-active' : 'btn-ghost'}`}
                onClick={() => setActiveTab('roadmap')}
              >
                <Icons.Map />
                <span className="hide-mobile">Roadmap</span>
              </button>
              {persona && (
                <div className="persona-badge">
                  <Icons.Mic />
                  <span className="hide-mobile">Persona</span>
                </div>
              )}
            </div>
          </header>

          {/* Content */}
          {activeTab === 'chat' ? (
            <div className="chat-container">
              {persona && <PersonaCard persona={persona} onClose={() => setPersona(null)} />}
              
              {messages.length === 0 ? (
                <WelcomeScreen onSuggestionClick={handleSendMessage} />
              ) : (
                <>
                  <div className="messages-area">
                    <div className="messages-list">
                      {messages.map(msg => (
                        <ChatMessage key={msg.id} message={msg} />
                      ))}
                      {isLoading && <TypingIndicator />}
                      <div ref={messagesEndRef} />
                    </div>
                  </div>
                  <ResourcesGrid resources={resources} />
                </>
              )}
              
              <ChatInput
                onSend={handleSendMessage}
                onVoiceResult={handleVoiceResult}
                isLoading={isLoading}
                placeholder="Ask about destinations, activities, or local tips..."
              />
            </div>
          ) : (
            <RoadmapDisplay
              roadmap={roadmap}
              isLoading={isLoadingRoadmap}
              onGenerate={handleGenerateRoadmap}
            />
          )}
        </div>
      );
    }

    // Render
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
